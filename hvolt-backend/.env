PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/hvolt

# JWT
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
JWT_RESET_SECRET=replace_with_another_long_random_secret
JWT_RESET_EXPIRES_IN=15m

# Frontend origin (for CORS + password reset links)
CLIENT_URL=http://localhost:5173

# Duplicate-report protection window, in minutes
DUPLICATE_REPORT_WINDOW_MINUTES=5

# Confirmations required before a report is auto-verified
AUTO_VERIFY_CONFIRMATIONS=5
